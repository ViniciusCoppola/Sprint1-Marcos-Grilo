    .section .text
    .global sensor_read_avg
    .align 2
# uint32_t sensor_read_avg(uint32_t *adc_addr, uint32_t samples)
# a0 = adc_addr, a1 = samples
sensor_read_avg:
    # prólogo: reservar espaço na pilha e salvar registradores callee-saved
    addi sp, sp, -16        # ajustar pilha
    sw   ra, 12(sp)         # salvar return address
    sw   s0, 8(sp)          # salvar s0 (usado como base)

    # inicialização
    mv   s0, a0             # s0 = ponteiro base para ADC
    mv   t0, a1             # t0 = número de amostras
    beqz t0, sr_zero        # se samples == 0, retorna 0

    li   t1, 0              # t1 = acumulador da soma (em registrador)
    li   t2, 0              # t2 = contador de iterações

sr_loop:
    lw   t3, 0(s0)          # ler valor do ADC (1 lw por amostra)
    add  t1, t1, t3         # acumular em registrador (evita stores)
    addi s0, s0, 4          # avançar ponteiro (assume array de words)
    addi t2, t2, 1          # incrementar contador
    blt  t2, a1, sr_loop    # repetir até ler todas as amostras

    # calcular média: a0 = soma / samples
    mv   a0, t1
    mv   a1, t2
    # usa div se a extensão M estiver disponível (RV32IM)
    div  a0, a0, a1         # a0 = média inteira

    j    sr_done

sr_zero:
    li   a0, 0              # se samples == 0, retorna 0

sr_done:
    # epílogo: restaurar registradores e retornar
    lw   ra, 12(sp)
    lw   s0, 8(sp)
    addi sp, sp, 16
    ret
